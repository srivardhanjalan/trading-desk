# Secrets — generated by setup.sh / containing API keys, never commit
.env
.mcp.json
# Exception: the plugin's MCP manifest IS tracked — it uses ${ENV_VAR} placeholders, no secrets
!trading-desk/.mcp.json

# MCP server clones — installed by setup.sh (legacy path) or by setup skill into ${CLAUDE_PLUGIN_DATA}
mcp-servers/

# Node
node_modules/

# Analysis reports (local state, cwd-relative)
reports/*.md
!reports/PLAN.md
reports/*.txt
reports/logs/

# FMP server PID file (created by start.sh)
.fmp.pid

# OS
.DS_Store
Thumbs.db

# Claude Code local settings
.claude/settings.local.json
