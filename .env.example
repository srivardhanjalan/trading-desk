# Trading Desk — API Keys
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
#
# Or run ./setup.sh which will prompt you interactively.
#
# Each line uses `export ` so that `source .env` puts the keys
# into the environment for the claude session (plugin MCP servers
# read ${ALPACA_API_KEY} etc. from env at startup).

# Financial Modeling Prep (https://financialmodelingprep.com/developer)
# Free tier: ~250 calls/day. Enough for 2 full analyses + 1 scan + morning brief.
export FMP_ACCESS_TOKEN=

# Alpaca Paper Trading (https://app.alpaca.markets/signup)
# Paper trading is free. No real money needed.
export ALPACA_API_KEY=
export ALPACA_SECRET_KEY=
export ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2
export ALPACA_PAPER=true

# FMP Server Port (default 8080)
export FMP_PORT=8080
