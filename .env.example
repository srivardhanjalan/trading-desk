# Trading Desk — API Keys
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
#
# Or run ./setup.sh which will prompt you interactively.

# Financial Modeling Prep (https://financialmodelingprep.com/developer)
# Free tier: ~250 calls/day. Enough for 2 full analyses + 1 scan + morning brief.
FMP_ACCESS_TOKEN=

# Alpaca Paper Trading (https://app.alpaca.markets/signup)
# Paper trading is free. No real money needed.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2
ALPACA_PAPER=true

# FMP Server Port (default 8080)
FMP_PORT=8080
